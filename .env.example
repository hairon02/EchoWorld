# Server Configuration
PORT=3001
NODE_ENV=development

# Database
MONGODB_URI=your-mongodb-uri
TEST_MONGODB_URI=your-test-mongodb-uri

# Azure Foundry IQ (World Knowledge Base)
AZURE_FOUNDRY_ENDPOINT=https://your-foundry-instance.openai.azure.com
AZURE_FOUNDRY_KEY=your-foundry-api-key
AZURE_FOUNDRY_TIMEOUT_MS=8000

# LLM Configuration
AZURE_OPENAI_ENDPOINT=https://your-azure-openai-resource.openai.azure.com
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-01
